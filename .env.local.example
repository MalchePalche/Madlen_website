# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER-ONLY. Used exclusively by app/api/create-order to
# insert orders past RLS. NEVER prefix it with NEXT_PUBLIC_ and never import it
# into client code; it grants full database access. Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Until these are set, the site runs on the local fallback catalogue
# (lib/mock-products.ts) so the UI is fully viewable.

# Resend — order confirmation emails (server-only; never expose to the client).
# Get an API key at https://resend.com. Without it, checkout still works and
# the email step is skipped silently.
RESEND_API_KEY=re_your_api_key
# Verified sender. For quick testing you can use the Resend sandbox address
# below (only delivers to your own Resend account email). Use your own
# verified domain in production, e.g. "Noem Studio <orders@yourdomain.bg>".
RESEND_FROM=Noem Studio <onboarding@resend.dev>

# Public base URL of the storefront — used to build absolute links in emails
# (product links, unsubscribe). Falls back to https://noem-studio.com if unset.
NEXT_PUBLIC_SITE_URL=https://noem-studio.com

# Daily newsletter digest — protects /api/newsletter/send-digest. Vercel Cron
# sends this automatically as `Authorization: Bearer <CRON_SECRET>`; you can
# also trigger a manual test send with ?secret=<CRON_SECRET>. Generate a long
# random value, e.g. `openssl rand -hex 32`. WITHOUT this set, the endpoint is
# disabled (fails closed) — it never sends to an unauthenticated caller.
CRON_SECRET=your-long-random-secret
