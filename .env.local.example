# Supabase — copy this file to .env.local and fill in your project values.
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Until these are set, the site runs on the local fallback catalogue
# (lib/mock-products.ts) so the UI is fully viewable.

# Resend — order confirmation emails (server-only; never expose to the client).
# Get an API key at https://resend.com. Without it, checkout still works and
# the email step is skipped silently.
RESEND_API_KEY=re_your_api_key
# Verified sender. For quick testing you can use the Resend sandbox address
# below (only delivers to your own Resend account email). Use your own
# verified domain in production, e.g. "Madlen <orders@yourdomain.bg>".
RESEND_FROM=Madlen <onboarding@resend.dev>
